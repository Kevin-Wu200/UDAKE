{
  "name": "udake_macos",
  "type": "commonjs",
  "version": "1.0.0",
  "description": "智能不确定性驱动空间决策平台",
  "main": "apps/electron/main.js",
  "scripts": {
    "dev": "vite --config configs/vite.config.ts",
    "dev:test": "vite --config configs/vite.config.ts --mode testing",
    "build": "tsc --noEmit -p configs/tsconfig.json && vite build --config configs/vite.config.ts && node scripts/replace-domains.js --mode=production",
    "build:incremental": "tsc --incremental --tsBuildInfoFile .tsbuildinfo/frontend.tsbuildinfo --noEmit -p configs/tsconfig.json && vite build --config configs/vite.config.ts",
    "build:dev": "tsc --noEmit -p configs/tsconfig.json && vite build --config configs/vite.config.ts --mode development && node scripts/replace-domains.js --mode=development",
    "build:test": "tsc --noEmit -p configs/tsconfig.json && vite build --config configs/vite.config.ts --mode testing && node scripts/replace-domains.js --mode=testing",
    "build:prod": "tsc --noEmit -p configs/tsconfig.json && vite build --config configs/vite.config.ts --mode production && node scripts/replace-domains.js --mode=production",
    "preview": "vite preview --config configs/vite.config.ts",
    "preview:test": "vite preview --config configs/vite.config.ts --mode testing",
    "lint": "eslint -c configs/eslint.config.mjs apps/frontend/js/",
    "lint:fix": "eslint -c configs/eslint.config.mjs apps/frontend/js/ --fix",
    "format": "prettier --config configs/.prettierrc --write 'apps/frontend/js/**/*.{js,ts,css}'",
    "format:check": "prettier --config configs/.prettierrc --check 'apps/frontend/js/**/*.{js,ts,css}'",
    "typecheck": "tsc --noEmit -p configs/tsconfig.json",
    "typecheck:completeness": "node scripts/type-completeness-check.js",
    "gps:battery:test": "node scripts/gps-battery-8h-test.js --hours=8 --sample-minutes=5",
    "track:benchmark": "node scripts/track-render-benchmark.js",
    "navigation:stability:test": "node scripts/navigation-stability-test.js",
    "memory:leak:test": "node scripts/memory-leak-detection.js --duration-sec=30 --interval-ms=1000 --max-projected-24h-mb=200",
    "memory:trend:analyze": "node scripts/memory-trend-analysis.js --max-projected-24h-mb=200",
    "realtime-sync:verify": "npm run gps:battery:test && npm run track:benchmark && npm run navigation:stability:test && npm run memory:leak:test && npm run memory:trend:analyze",
    "quality:check": "npm run lint && npm run format:check && npm run typecheck && npm run typecheck:completeness",
    "qa:phase1:audit": "node scripts/qa-phase1-audit.js",
    "qa:phase1:audit:strict": "node scripts/qa-phase1-audit.js --strict",
    "qa:phase1:check": "npm run qa:phase1:audit && npm run test:security && npm run test:performance",
    "qa:phase2:audit": "node scripts/qa-phase2-audit.js",
    "qa:phase2:audit:strict": "node scripts/qa-phase2-audit.js --strict",
    "qa:phase2:check": "npm run qa:phase2:audit && npm run test:e2e:explain-panel && npm run test:performance",
    "test": "vitest --config configs/vitest.config.js --run",
    "test:watch": "vitest --config configs/vitest.config.js",
    "test:coverage": "vitest --config configs/vitest.config.js --run --coverage",
    "test:coverage:explain-panel": "vitest --config configs/vitest.explain.config.js --run --coverage",
    "test:replace-domains": "vitest --config configs/vitest.config.js --run tests/replace-domains.test.js",
    "coverage:report": "node scripts/coverage-report.js",
    "test:security": "vitest --config configs/vitest.config.js --run tests/security.test.ts",
    "test:e2e": "playwright test --config configs/playwright.config.ts",
    "test:e2e:explain-panel": "playwright test --config configs/playwright.config.ts tests/e2e/spatiotemporal-explain-panel.test.ts",
    "test:e2e:workflow": "playwright test --config configs/playwright.workflow.config.ts tests/e2e/workflow-editor.test.ts tests/e2e/workflow-execution.test.ts tests/e2e/workflow-templates.test.ts tests/e2e/notification-center.spec.ts",
    "test:e2e:auth": "playwright test --config configs/playwright.auth.config.ts",
    "test:e2e:report": "node scripts/e2e-flakiness-report.js",
    "test:e2e:ui": "playwright test --config configs/playwright.config.ts --ui",
    "test:performance": "vitest --config configs/vitest.config.js --run tests/performance-monitor.test.ts tests/performance/notification-center.performance.test.ts tests/load/notification-load.test.ts",
    "i18n:check": "node scripts/i18n-check.js",
    "i18n:check:strict": "node scripts/i18n-check.js --strict",
    "i18n:tms:export": "node scripts/i18n-tms.js export",
    "i18n:tms:validate": "node scripts/i18n-tms.js validate",
    "i18n:tms:validate:strict": "node scripts/i18n-tms.js validate --strict",
    "deps:check": "npm ls --depth=0",
    "deps:audit": "npm audit --omit=dev --audit-level=high",
    "build:electron": "electron-builder",
    "build:mac": "npm run build:prod && npm run build:electron -- --mac && node scripts/copy-mac-artifact.js",
    "build:windows": "npm run build:prod && npm run build:electron -- --win && node scripts/copy-windows-artifact.js",
    "build:android": "npm run build:prod && node scripts/update-capacitor-config.js && npx cap sync android && cd android && ./gradlew assembleRelease && cd ..",
    "build:all": "npm run build:prod && npm run build:android && npm run build:electron"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/geojson": "^7946.0.16",
    "@vitest/coverage-v8": "^4.1.0",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "eslint": "^10.0.3",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/device": "^8.0.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/geolocation": "^8.1.0",
    "@capacitor/haptics": "^8.0.1",
    "@capacitor/local-notifications": "^8.0.2",
    "@geoscene/core": "^4.33.19",
    "echarts": "^6.0.0",
    "socket.io-client": "^4.8.3"
  },
  "build": {
    "appId": "com.udake.app",
    "productName": "UDAKE",
    "directories": {
      "output": "release",
      "buildResources": "logo"
    },
    "files": [
      "apps/electron/**/*",
      "apps/frontend/dist/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "logo/UDAKE.icns",
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "logo/UDAKE.ico",
      "artifactName": "${productName}-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "UDAKE",
      "uninstallDisplayName": "UDAKE",
      "runAfterFinish": true
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      },
      "background": "build/dmg-background.png"
    },
    "afterSign": "scripts/notarize.js"
  }
}
