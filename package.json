{
  "name": "udake_macos",
  "type": "commonjs",
  "version": "1.0.0",
  "description": "智能不确定性驱动空间决策平台",
  "main": "apps/electron/main.js",
  "scripts": {
    "dev": "vite --config configs/vite.config.ts",
    "dev:test": "vite --config configs/vite.config.ts --mode testing",
    "build": "tsc --noEmit -p configs/tsconfig.json && vite build --config configs/vite.config.ts",
    "build:incremental": "tsc --incremental --tsBuildInfoFile .tsbuildinfo/frontend.tsbuildinfo --noEmit -p configs/tsconfig.json && vite build --config configs/vite.config.ts",
    "build:dev": "tsc --noEmit -p configs/tsconfig.json && vite build --config configs/vite.config.ts --mode development",
    "build:test": "tsc --noEmit -p configs/tsconfig.json && vite build --config configs/vite.config.ts --mode testing",
    "build:prod": "tsc --noEmit -p configs/tsconfig.json && vite build --config configs/vite.config.ts --mode production",
    "preview": "vite preview --config configs/vite.config.ts",
    "preview:test": "vite preview --config configs/vite.config.ts --mode testing",
    "lint": "eslint -c configs/eslint.config.mjs apps/frontend/js/",
    "lint:fix": "eslint -c configs/eslint.config.mjs apps/frontend/js/ --fix",
    "format": "prettier --config configs/.prettierrc --write 'apps/frontend/js/**/*.{js,ts,css}'",
    "format:check": "prettier --config configs/.prettierrc --check 'apps/frontend/js/**/*.{js,ts,css}'",
    "typecheck": "tsc --noEmit -p configs/tsconfig.json",
    "test": "vitest --config configs/vitest.config.js --run",
    "test:watch": "vitest --config configs/vitest.config.js",
    "test:coverage": "vitest --config configs/vitest.config.js --run --coverage",
    "test:security": "vitest --config configs/vitest.config.js --run tests/security.test.ts",
    "test:e2e": "playwright test --config configs/playwright.config.ts",
    "test:e2e:ui": "playwright test --config configs/playwright.config.ts --ui",
    "test:performance": "vitest --config configs/vitest.config.js --run tests/performance-monitor.test.ts",
    "i18n:check": "node scripts/i18n-check.js",
    "i18n:check:strict": "node scripts/i18n-check.js --strict",
    "deps:check": "npm ls --depth=0",
    "deps:audit": "npm audit --omit=dev --audit-level=high",
    "build:electron": "npm run build:prod && electron-builder --mac",
    "build:android": "npm run build:prod && node scripts/update-capacitor-config.js && npx cap sync android && cd android && ./gradlew assembleRelease && cd ..",
    "build:all": "npm run build:prod && npm run build:android && npm run build:electron"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-v8": "^4.1.0",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "eslint": "^10.0.3",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/device": "^8.0.1",
    "@capacitor/geolocation": "^8.1.0",
    "@capacitor/haptics": "^8.0.1",
    "@capacitor/local-notifications": "^8.0.2",
    "echarts": "^6.0.0",
    "socket.io-client": "^4.8.3"
  },
  "build": {
    "appId": "com.udake.app",
    "productName": "UDAKE",
    "directories": {
      "output": "release",
      "buildResources": "logo"
    },
    "files": [
      "apps/electron/**/*",
      "apps/frontend/dist/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "logo/UDAKE.icns",
      "category": "public.app-category.science",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    }
  }
}
