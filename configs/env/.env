# ============================================
# UDAKE 项目环境变量配置
# ============================================

# 应用配置
APP_NAME=智能不确定性驱动空间决策平台
VERSION=1.0.0
DEBUG=True

# 服务器配置
HOST=0.0.0.0
PORT=8000
IPCONFIG={BACKEND_IP}

#使用 PostgreSQL 认证库 (udake_auth)
DATABASE_URL=postgresql://{YOUR_USER_NAME}:{YOUR_PASSWORD}@{POSTGRESQL_IP}:5432/udake_auth
AUTH_DATABASE_URL=postgresql://{YOUR_USER_NAME}:{YOUR_PASSWORD}@{POSTGRESQL_IP}:5432/udake_auth

# 本地开发默认关闭 SSL；生产环境建议开启并配置证书路径。
AUTH_DB_REQUIRE_SSL=false
AUTH_DB_SSLMODE=disable
AUTH_DB_SSLCERT=
AUTH_DB_SSLKEY=
AUTH_DB_SSLROOTCERT=

# Redis 默认按本机配置；未启用时不影响服务启动。
REDIS_ENABLED=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0

# CORS配置
BACKEND_CORS_ORIGINS=["http://{BACKEND_IP}:5173","http://{BACKEND_IP}:3000","https://localhost","http://localhost","capacitor://localhost","ionic://localhost"]

# 文件上传配置
MAX_FILE_SIZE_MB=6144

# 任务配置
MAX_CONCURRENT_TASKS=10
TASK_TIMEOUT=3600

# 克里金配置
DEFAULT_VARIOGRAM_MODEL=spherical
GRID_RESOLUTION=100

# ============================================
# 地图引擎 API 密钥配置
# ============================================

# GeoScene 配置
GEOSCENE_API_KEY=DEV_MOCK_GEOSCENE_KEY
GEOSCENE_PORTAL_URL=https://www.geoscene.cn
GEOSCENE_ENV=development
GEOSCENE_DEFAULT_BASEMAP=streets-vector
GEOSCENE_DEFAULT_CENTER=[116.38,39.9]        #默认地图中心为北京
GEOSCENE_DEFAULT_ZOOM=10

# 高德地图配置
AMAP_API_KEY=2f3f114aa5671425aa3c52f707d741c5
AMAP_SECURITY_CODE=10b5ef21f6b36d09e24d7b076d35dccc
VITE_AMAP_API_KEY=2f3f114aa5671425aa3c52f707d741c5
VITE_AMAP_SECURITY_CODE=10b5ef21f6b36d09e24d7b076d35dccc

# ============================================
# 前端API配置
# ============================================
VITE_API_BASE_URL=http://{BACKEND_IP}:8000
VITE_WS_URL=ws://{BACKEND_IP}:8000

# 官网配置
OFFICIAL_WEB={OFFICIAL_WEB}

# 管理员后台配置
ADMIN_WEB={ADMIN_WEB}
# SMTP 邮件通知配置（默认QQ邮箱）
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=15
SMTP_POOL_SIZE=4
WORKFLOW_EMAIL_WORKERS=2
WORKFLOW_EMAIL_USER_LIMIT_PER_HOUR=10
WORKFLOW_EMAIL_EVENT_LIMIT_PER_HOUR=30
WORKFLOW_EMAIL_DEDUP_SECONDS=300
WORKFLOW_EMAIL_RETRY_BACKOFF_SECONDS=60,300,900
