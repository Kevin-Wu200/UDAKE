# ============================================
# UDAKE 项目环境变量配置
# ============================================

# 应用配置
APP_NAME=智能不确定性驱动空间决策平台
VERSION=1.0.0
DEBUG=True

# 服务器配置
HOST=0.0.0.0
PORT=8000
IPCONFIG={YOUR_IP_CONFIG}

# ============================================
# 后端关键依赖配置（第二章节排查补齐）
# ============================================
#默认使用 PostgreSQL 认证库 (udake_auth)
DATABASE_URL={YOUR_DATABASE_URL}
AUTH_DATABASE_URL={YOUR_AUTH_DATABASE_URL}

# 本地开发默认关闭 SSL；生产环境建议开启并配置证书路径。
AUTH_DB_REQUIRE_SSL=false
AUTH_DB_SSLMODE=disable
AUTH_DB_SSLCERT={YOUR_AUTH_DB_SSLCERT}
AUTH_DB_SSLKEY={YOUR_AUTH_DB_SSLKEY}
AUTH_DB_SSLROOTCERT={YOUR_AUTH_DB_SSLROOTCERT}

# Redis 默认按本机配置；未启用时不影响服务启动。
REDIS_ENABLED=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0

# CORS配置
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://{YOUR_IP_CONFIG}:5173","http://{YOUR_IP_CONFIG}:3000","https://localhost","http://localhost","capacitor://localhost","ionic://localhost"]

# 文件上传配置
MAX_FILE_SIZE_MB=100

# 任务配置
MAX_CONCURRENT_TASKS=5
TASK_TIMEOUT=3600

# 克里金配置
DEFAULT_VARIOGRAM_MODEL=spherical
GRID_RESOLUTION=100

# ============================================
# 地图引擎 API 密钥配置
# ============================================

# ============================================
# GeoScene Enterprise 认证配置
# 来源: ~/UDAKE/TODOList/GeoScene配置.txt
# ============================================
# 认证模式: "apikey" (API Key) 或 "enterprise" (企业账号密码)
GEOSCENE_AUTH_MODE=enterprise

# GeoScene Enterprise 服务器门户地址
# Portal URL (不含 /webapps/ 后缀, SDK默认拼接)
GEOSCENE_PORTAL_URL={YOUR_GEOSCENE_PORTAL_URL}

# GeoScene Enterprise 企业账号认证 (Portal管理员)
GEOSCENE_USERNAME={YOUR_GEOSCENE_USERNAME}
GEOSCENE_PASSWORD={YOUR_GEOSCENE_PASSWORD}

# GeoScene API Key (API Key 模式下使用)
# 当 AUTH_MODE=apikey 时生效，enterprise 模式下可留空
GEOSCENE_API_KEY={YOUR_GEOSCENE_API_KEY}

# GeoScene 环境标识
GEOSCENE_ENV=development

# GeoScene 默认底图
GEOSCENE_DEFAULT_BASEMAP=streets-vector

# GeoScene 默认中心点 (经度, 纬度) - 北京天安门
GEOSCENE_DEFAULT_CENTER=[116.39122,39.90735]

# GeoScene 默认缩放级别
GEOSCENE_DEFAULT_ZOOM=10

# GeoScene Enterprise Token 服务地址
# Portal 共享 REST 接口: {portalUrl}/sharing/rest/generateToken
GEOSCENE_TOKEN_URL=https://gis:7443/geoscene/sharing/rest/generateToken

# 高德地图配置
AMAP_API_KEY={YOUR_AMAP_API_KEY}
AMAP_SECURITY_CODE={YOUR_AMAP_SECURITY_CODE}
VITE_AMAP_API_KEY={YOUR_VITE_AMAP_API_KEY}
VITE_AMAP_SECURITY_CODE={YOUR_VITE_AMAP_SECURITY_CODE}

# ============================================
# 前端API配置
# ============================================
VITE_API_BASE_URL=http://{YOUR_IP_CONFIG}:8000
VITE_WS_URL=ws://{YOUR_IP_CONFIG}:8000

# 官网配置
OFFICIAL_WEB={YOUR_OFFICIAL_WEB}

# 管理员后台配置
ADMIN_WEB={YOUR_ADMIN_WEB}

# 企业管理配置
ENTERPRISE_WEB={YOUR_ENTERPRISE_WEB}

# SMTP 邮件通知配置
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER={YOUR_SMTP_USER}
SMTP_PASSWORD={YOUR_SMTP_PASSWORD}
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=15
SMTP_POOL_SIZE=4
WORKFLOW_EMAIL_WORKERS=2
WORKFLOW_EMAIL_USER_LIMIT_PER_HOUR=10
WORKFLOW_EMAIL_EVENT_LIMIT_PER_HOUR=30
WORKFLOW_EMAIL_DEDUP_SECONDS=300
WORKFLOW_EMAIL_RETRY_BACKOFF_SECONDS=60,300,900
