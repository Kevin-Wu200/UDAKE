# ============================================
# UDAKE 测试环境配置
# ============================================

# 应用配置
APP_NAME=智能不确定性驱动空间决策平台
VERSION=1.0.0
DEBUG=True

# 服务器配置
HOST=0.0.0.0
PORT=8000

# CORS配置
BACKEND_CORS_ORIGINS=["http://{BACKEND_IP}:5174","http://{BACKEND_IP}:3000","https://localhost","http://localhost","capacitor://localhost","ionic://localhost"]

# 地图引擎 API 密钥配置
AMAP_API_KEY=2f3f114aa5671425aa3c52f707d741c5
AMAP_SECURITY_CODE=10b5ef21f6b36d09e24d7b076d35dccc

# 前端 API 配置
VITE_API_BASE_URL=http://{BACKEND_IP}:8000
VITE_WS_URL=ws://{BACKEND_IP}:8000

# 官网配置
OFFICIAL_WEB={OFFICIAL_WEB}

# 管理员后台配置
ADMIN_WEB={ADMIN_WEB}

# SMTP 邮件通知配置（默认使用QQ邮箱）
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=15
SMTP_POOL_SIZE=4
WORKFLOW_EMAIL_WORKERS=2
WORKFLOW_EMAIL_USER_LIMIT_PER_HOUR=10
WORKFLOW_EMAIL_EVENT_LIMIT_PER_HOUR=30
WORKFLOW_EMAIL_DEDUP_SECONDS=300
WORKFLOW_EMAIL_RETRY_BACKOFF_SECONDS=60,300,900
