# SMTP 配置
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=CHANGE_ME
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=15
SMTP_POOL_SIZE=4
AUTH_SUPER_ADMIN_EMAILS=1447954419@qq.com

# 邮件服务控制
WORKFLOW_EMAIL_WORKERS=2
WORKFLOW_EMAIL_USER_LIMIT_PER_HOUR=10
WORKFLOW_EMAIL_EVENT_LIMIT_PER_HOUR=30
WORKFLOW_EMAIL_DEDUP_SECONDS=300
WORKFLOW_EMAIL_RETRY_BACKOFF_SECONDS=60,300,900

# 定时任务调度配置
KEY_EXPIRY_SCHEDULER_ENABLED=true
KEY_EXPIRY_SCHEDULER_POLL_SECONDS=20
KEY_EXPIRY_SCHEDULER_EXPIRE_TIME=00:10
KEY_EXPIRY_SCHEDULER_REMINDER_TIME=00:20
KEY_EXPIRY_SCHEDULER_HISTORY_LIMIT=200
KEY_EXPIRY_REMINDER_RETRY_TIMES=3
KEY_EXPIRY_REMINDER_RETRY_INTERVAL_SECONDS=60
