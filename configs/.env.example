# ============================================
# UDAKE 项目环境变量配置示例文件
# ============================================
# 说明：复制此文件为 .env 并填入实际的配置值
# ============================================

# 应用配置
APP_NAME=智能不确定性驱动空间决策平台
VERSION=1.0.0
DEBUG=True

# 服务器配置
HOST=0.0.0.0
PORT=8000
IPCONFIG=localhost
BACKEND_PORT=8000
FRONTEND_PORT=5173

# 统一网络地址配置（建议由部署环境注入）
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
WS_URL=ws://localhost:8000

# 前端 API 配置（Vite 暴露给客户端）
# 生产环境必须使用 HTTPS/WSS
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
VITE_BACKEND_HOST=localhost
VITE_BACKEND_PORT=8000
VITE_FRONTEND_PORT=5173
VITE_FRONTEND_URL=http://localhost:5173
VITE_ENABLE_HTTPS=true

# CORS配置
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","https://localhost","http://localhost","capacitor://localhost","ionic://localhost"]

# 文件上传配置
MAX_FILE_SIZE_MB=100

# 任务配置
MAX_CONCURRENT_TASKS=5
TASK_TIMEOUT=3600

# 克里金配置
DEFAULT_VARIOGRAM_MODEL=spherical
GRID_RESOLUTION=100

# ============================================
# 地图引擎 API 密钥配置
# ============================================

# ArcGIS 配置
ARCGIS_API_KEY=YOUR_ARCGIS_API_KEY_HERE
ARCGIS_PORTAL_URL=https://www.arcgis.com
ARCGIS_ENV=development
ARCGIS_DEFAULT_BASEMAP=streets-vector
ARCGIS_DEFAULT_CENTER=[139.767125,35.681236]
ARCGIS_DEFAULT_ZOOM=10

# 高德地图配置
# 注意：Vite 只会暴露以 VITE_ 开头的环境变量到客户端代码
VITE_AMAP_API_KEY=YOUR_AMAP_API_KEY_HERE
VITE_AMAP_SECURITY_CODE=YOUR_AMAP_SECURITY_CODE_HERE

# 天地图配置
TIANDITU_API_KEY=YOUR_TIANDITU_API_KEY_HERE
TIANDITU_TOKEN=YOUR_TIANDITU_TOKEN_HERE

# ============================================
# 数据库配置（可选）
# ============================================

# DATABASE_URL=postgresql://user:password@localhost:5432/udake
# AUTH_DATABASE_URL=postgresql://user:password@localhost:5432/udake_auth
# AUTH_DB_POOL_SIZE=10
# AUTH_DB_MAX_OVERFLOW=20
# AUTH_DB_POOL_TIMEOUT=30
# AUTH_DB_POOL_RECYCLE=1800
# AUTH_DB_PRE_PING=True
# REDIS_URL=redis://localhost:6379/0

# ============================================
# 日志配置
# ============================================

# LOG_LEVEL=INFO
# LOG_FILE=logs/app.log

# ============================================
# AI 扩展模块配置
# ============================================

# AI_MODEL_PATH=/path/to/models
# AI_CACHE_ENABLED=True
# AI_MAX_BATCH_SIZE=100

# ============================================
# 移动端配置
# ============================================

# MOBILE_APP_ID=com.udake.app
# MOBILE_APP_VERSION=1.0.0
