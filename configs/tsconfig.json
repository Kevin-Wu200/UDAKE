{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "incremental": true,
    "tsBuildInfoFile": "../.tsbuildinfo/frontend.tsbuildinfo",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationDir": "../apps/frontend/types/generated",
    "outDir": "../dist",
    "rootDir": "../apps/frontend",
    "baseUrl": "../apps/frontend",
    "paths": {
      "@services/*": ["js/services/*"],
      "@components/*": ["js/components/*"],
      "@utils/*": ["js/utils/*"],
      "@models/*": ["js/models/*"],
      "@map/*": ["js/map/*"],
      "@adapters/*": ["js/adapters/*"],
      "@sampling/*": ["js/sampling/*"],
      "@config/*": ["js/config/*"]
    },
    "noImplicitAny": false,
    "strictNullChecks": false,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": false,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "downlevelIteration": true,
    "allowSyntheticDefaultImports": true,
    "allowUmdGlobalAccess": true,
    "typeRoots": ["../apps/frontend/types"],
    "types": ["宽松类型声明"]
  },
  "include": [
    "../apps/frontend/js/**/*",
    "../apps/frontend/types/**/*",
    "../apps/frontend/types/global.d.ts",
    "../apps/frontend/vite-env.d.ts"
  ],
  "exclude": [
    "../node_modules",
    "../dist",
    "../venv",
    "../services/backend"
  ]
}
