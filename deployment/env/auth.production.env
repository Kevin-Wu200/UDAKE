# ===== 基础环境 =====
ENVIRONMENT=production
DEBUG=False
HOST=0.0.0.0
PORT=8000

# ===== 域名与CORS =====
FRONTEND_SERVER_NAME=${ADMIN_WEB}
BACKEND_CORS_ORIGINS=["${ADMIN_WEB}","${OFFICIAL_WEB}"]

# ===== 数据库 =====
POSTGRES_DB=udake_auth
POSTGRES_USER=udake
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
AUTH_DATABASE_URL=postgresql+psycopg2://udake:CHANGE_ME_DB_PASSWORD@postgres:5432/udake_auth
AUTH_DB_REQUIRE_SSL=False
AUTH_DB_SSLMODE=require
AUTH_DB_POOL_SIZE=20
AUTH_DB_MAX_OVERFLOW=40
AUTH_DB_POOL_TIMEOUT=30
AUTH_DB_POOL_RECYCLE=1800

# ===== Redis =====
REDIS_URL=redis://redis:6379/0
REDIS_ENABLED=True

# ===== 邮件服务 =====
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=auth@example.com
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
SMTP_FROM_EMAIL=auth@example.com
SMTP_USE_TLS=True
SMTP_TIMEOUT_SECONDS=15

# ===== 认证密钥 =====
AUTH_JWT_SECRET=CHANGE_ME_JWT_SECRET
AUTH_ENCRYPTION_KEY=CHANGE_ME_32_BYTES_HEX_KEY
AUTH_SECURITY_ALERT_EMAIL=security@example.com

# ===== 安全策略 =====
AUTH_CSRF_ENABLED=True
AUTH_CSRF_COOKIE_SECURE=True
AUTH_CSRF_COOKIE_SAMESITE=strict
AUTH_ACCOUNT_LOCK_5_FAIL_SECONDS=1800
AUTH_ACCOUNT_LOCK_10_FAIL_SECONDS=86400
AUTH_IP_AUTO_BAN_THRESHOLD=10
AUTH_IP_AUTO_BAN_WINDOW_SECONDS=3600
AUTH_IP_AUTO_BAN_SECONDS=1800

# ===== 日志 =====
LOG_LEVEL=INFO
LOG_FILE=/var/log/udake/auth-backend.log
