# 时空克里金模块生产环境变量模板
ENVIRONMENT=production
DEBUG=False
HOST=0.0.0.0
PORT=8000

# 反向代理
DOMAIN=kriging.example.com
TLS_CERT_PATH=./certs/fullchain.pem
TLS_KEY_PATH=./certs/privkey.pem

# 数据库与缓存
DATABASE_URL=postgresql+psycopg2://udake:change_me@postgres:5432/udake_kriging
AUTH_DATABASE_URL=postgresql+psycopg2://udake:change_me@postgres:5432/udake_kriging
AUTH_DB_REQUIRE_SSL=False
REDIS_ENABLED=True
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# 安全与密钥
AUTH_JWT_SECRET=please_change_to_very_strong_secret
AUTH_ENCRYPTION_KEY=please_change_to_32bytes_hex
GEOSCENE_API_KEY=YOUR_GEOSCENE_API_KEY_HERE
AMAP_API_KEY=
AMAP_SECURITY_CODE=
TIANDITU_API_KEY=YOUR_TIANDITU_API_KEY_HERE

# CORS（JSON 数组字符串）
BACKEND_CORS_ORIGINS=["https://kriging.example.com"]

# 日志
LOG_LEVEL=INFO
LOG_FILE=/var/log/udake/backend.log

# 备份
BACKUP_RETENTION_DAYS=14
BACKUP_ROOT=./backups
OFFSITE_BACKUP_DIR=/data/offsite/udake-kriging
