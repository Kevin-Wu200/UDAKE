# 数据库连接
DATABASE_URL=postgresql+psycopg2://udake:change_me@postgres:5432/udake_kriging
AUTH_DATABASE_URL=postgresql+psycopg2://udake:change_me@postgres:5432/udake_auth

# 缓存参数
REDIS_ENABLED=True
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# 日志级别
LOG_LEVEL=INFO
LOG_FILE=/var/log/udake/backend.log

# 安全参数
AUTH_JWT_SECRET=please_change_to_very_strong_secret
AUTH_ENCRYPTION_KEY=please_change_to_32bytes_hex
BACKEND_CORS_ORIGINS=["https://kriging.example.com"]
AUTH_DB_REQUIRE_SSL=False

# 性能参数
WORKER_PROCESSES=4
MAX_REQUESTS=2000
REQUEST_TIMEOUT_SECONDS=60

# 资源限制
BACKEND_CPU_LIMIT=2
BACKEND_MEMORY_LIMIT=4g
POSTGRES_MEMORY_LIMIT=4g

# 网络参数
DOMAIN=kriging.example.com
PORT=8000
HEALTHCHECK_PATH=/health
