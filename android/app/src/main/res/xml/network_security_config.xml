<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        开发环境：允许明文 HTTP（Android <domain> 不支持 IP 地址，
        而局域网后端通过 IP 访问，因此 base-config 必须放行明文流量）。
        生产环境应改回 cleartextTrafficPermitted="false" 并使用 HTTPS。
    -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
</network-security-config>
