# ============================================
# UDAKE 项目环境变量配置
# ============================================
# 说明：请在此文件中填入实际的配置值
# ============================================

# 应用配置
APP_NAME=智能不确定性驱动空间决策平台
VERSION=1.0.0
DEBUG=True

# 服务器配置
HOST=0.0.0.0
PORT=8000

# CORS配置
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://127.0.0.1:5173"]

# 文件上传配置
MAX_FILE_SIZE_MB=100

# 任务配置
MAX_CONCURRENT_TASKS=5
TASK_TIMEOUT=3600

# 克里金配置
DEFAULT_VARIOGRAM_MODEL=spherical
GRID_RESOLUTION=100

# ============================================
# 地图引擎 API 密钥配置
# ============================================

# ArcGIS 配置
ARCGIS_API_KEY=YOUR_ARCGIS_API_KEY_HERE
ARCGIS_PORTAL_URL=https://www.arcgis.com
ARCGIS_ENV=development
ARCGIS_DEFAULT_BASEMAP=streets-vector
ARCGIS_DEFAULT_CENTER=[139.767125,35.681236]
ARCGIS_DEFAULT_ZOOM=10

# 高德地图配置
# 注意：Vite 只会暴露以 VITE_ 开头的环境变量到客户端代码
# 获取高德地图 API 密钥：https://console.amap.com/
# 创建应用后，获取 Web端（JS API）的 Key 和 安全密钥
VITE_AMAP_API_KEY=2f3f114aa5671425aa3c52f707d741c5
VITE_AMAP_SECURITY_CODE=10b5ef21f6b36d09e24d7b076d35dccc

# 天地图配置
TIANDITU_API_KEY=YOUR_TIANDITU_API_KEY_HERE
TIANDITU_TOKEN=YOUR_TIANDITU_TOKEN_HERE