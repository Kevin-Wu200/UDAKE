{"id": "geojson-importer", "name": "GeoJSON 数据导入插件", "version": "1.0.0", "description": "支持导入和解析 GeoJSON 格式的地理空间数据", "author": "UDAKE Team", "type": "data-importer", "main": "./GeoJSONImporter.ts", "loader": "local", "config": {"maxFileSize": 10485760, "supportedFeatures": ["Point", "LineString", "Polygon", "MultiPoint", "MultiLineString", "MultiPolygon", "GeometryCollection", "Feature", "FeatureCollection"]}, "permissions": ["data:import", "data:parse", "data:validate"], "minAppVersion": "1.0.0"}